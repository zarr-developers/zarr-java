{
  "zarr_format": 3,
  "node_type": "array",
  "shape": [3, 4],
  "data_type": "float64",
  "fill_value": 0.0,
  "chunk_grid": {
    "name": "regular",
    "configuration": { "chunk_shape": [3, 4] }
  },
  "chunk_key_encoding": {
    "name": "default",
    "configuration": { "separator": "/" }
  },
  "codecs": [
    { "name": "bytes", "configuration": { "endian": "little" } },
    { "name": "zstd", "configuration": { "level": 3 } }
  ],
  "dimension_names": ["row", "col"]
}
